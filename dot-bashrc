    function cleartechit() { \rm ${1%.*}.{abs,aux,bbl,bcf,blg,brf,dvi,fdb_latexmk,fff,fls,idx,ilg,ind,loc,lof,log,lot,maf,mtc,mtc?,nav,out,run.xml,snm,soc,spl,synctex.gz,tex.flc,tex~,thm,toc,ttt} ; }
