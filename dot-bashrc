# --------------------------------------------------------------------
# Non-interactive
#

# directory with setup scripts
bashd=${HOME}/.bash.d
[[ -d ${bashd} ]] || { echo "no .bash.d directory"; return; }

# set homebrew also in non-interactive scripts
if [[ -z ${HOMEBREW_PREFIX} ]] ; then
    [[ -f ${bashd}/homebrew.sh ]] && source ${bashd}/homebrew.sh
fi

# make sure /usr/local/bin is at the beginning of PATH
if [[ -n $(echo ${PATH} | grep "/usr/local/bin") ]] ; then
    export PATH=$(echo ${PATH} | sed 's|^/usr/local/bin:||' | sed 's|:/usr/local/bin$||' | sed 's|:/usr/local/bin:|:|')
fi
export PATH=/usr/local/bin:${PATH}

# use pyenv also in non-interactive scripts
if [[ -z ${PYENV_ROOT} ]] ; then
    [[ -f ${bashd}/pyenv.sh ]] && source ${bashd}/pyenv.sh
fi

# Use miniconda in non-interactive scripts
if [[ -z ${CONDA_PREFIX} ]] ; then
    [[ -f ${bashd}/conda.sh ]] && source ${bashd}/conda.sh
fi

# set licence keys
ossystem=$(uname -s)
if [[ ${ossystem} == [Dd]arwin && -z ${NAG_KUSARI_FILE} ]] ; then
    [[ -f ${bashd}/licence.sh ]] && source ${bashd}/licence.sh
fi

# IDL/GDL
if [[ -z ${IDL_DIR} ]] ; then
    [[ -d /Applications/itt/idl ]] && export IDL_DIR=/Applications/itt/idl
    [[ -d /Applications/exelis/idl ]] && export IDL_DIR=/Applications/exelis/idl
fi
if [[ -z ${IDL_STARTUP} ]] ; then
    export IDL_STARTUP=${HOME}/bin/idlstartup.pro
fi

# more pathes
source ${bashd}/bash_lib.sh

# matthias' bash and python utilities
[[ -z $(echo ${PATH} | grep "${HOME}/bin") ]] && export PATH=$(prepath ${PATH} ${HOME}/bin)
[[ -z $(echo ${PATH} | grep "${HOME}/prog/jams/utils") ]] && export PATH=$(prepath ${PATH} ${HOME}/prog/jams/utils)
[[ -z $(echo ${PATH} | grep "${HOME}/prog/github/ido") ]] && export PATH=$(prepath ${PATH} ${HOME}/prog/github/ido)

# local bin on clusters
if [[ -d ${HOME}/local ]] ; then
    if [[ -z $(echo ${PATH} | grep "${HOME}/local/bin") ]] ; then
	export PATH=$(prepath ${PATH} ${HOME}/local/bin)
	export LD_LIBRARY_PATH=$(apppath ${LD_LIBRARY_PATH} ${HOME}/local/lib)
    fi
fi

# other software on macOS
if [[ ${ossystem} == [Dd]arwin ]] ; then
    # homebrew
    if [[ -n ${HOMEBREW_PREFIX} ]] ; then
	# anaconda might install netcdf, which is hence in ${HOME}/.pyenv/shims
	# but anaconda might not be the active python version and ncdump,
	# for example, might not work -> use version of homebrew
	[[ -z $(echo ${PATH} | grep "${HOMEBREW_PREFIX}/opt/netcdf/bin") ]] && export PATH=$(prepath ${PATH} ${HOMEBREW_PREFIX}/opt/netcdf/bin)
    fi

    [[ -z $(echo ${PATH} | grep "/opt/pkgconfig/bin") ]] && export PATH=$(apppath ${PATH} /opt/pkgconfig/bin)

    # Python.frameworks not implemented here
    # for ((i=6; i<=20; i++)) ; do
    #     export PATH=$(apppath ${PATH} /Library/Frameworks/Python.framework/Versions/3.${i}/bin)
    # done
fi

